PORT=4000

# Neon connection string (Dashboard → Connection details → Connection string)
# Example: postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@skygnosis.demo
ADMIN_PASSWORD=Admin123!

# Google AI Studio → Get API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=15000

FRONTEND_URL=http://localhost:3000
